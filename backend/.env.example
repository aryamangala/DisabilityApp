# Copy to `.env` for local runs only. Never commit real values.
# Production: set these on your host (e.g. Railway service Variables), not in the repo.

# Required for OCR + Easy Read generation (server-side only — never in the mobile app)
OPENAI_API_KEY=

# Optional model override (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

NODE_ENV=development
PORT=4000

# Verbose HTTP/OpenAI tracing (default: on when NODE_ENV is not production)
# LOG_VERBOSE=true

# Rate limiting / CORS (see server.mjs)
# CORS_ORIGIN=https://your-web-app.example

# Never enable on public production unless protected
# ALLOW_DIAGNOSTICS=true

# AWS Cognito (required for auth)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# PostgreSQL / Amazon RDS (required)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=disabilityapp
DB_USER=postgres
DB_PASSWORD=
