# Optional: override backend when running `npx expo start`.
# If unset, the app uses defaultPublicBackend.json (and app.config extra) so Expo Go on a phone hits Railway.
# For a local API, set e.g. EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:4000
# EAS builds: also set EXPO_PUBLIC_BACKEND_URL in eas.json to match defaultPublicBackend.json.
EXPO_PUBLIC_BACKEND_URL=https://disabilityapp.up.railway.app
