# EAS Build reads this file when resolving app.config.js. Link the project once:
#   cd mobile && npx eas-cli init
# Then either commit the generated `extra.eas.projectId` in app.config.js, or set:
# EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# (from https://expo.dev → your project → Project settings → Project ID)

# -----------------------------------------------------------------------------
# Expo / EAS — variables prefixed EXPO_PUBLIC_ are embedded in the client JS bundle.
# Anyone can read them (extract APK/IPA or Metro bundle). Never put API keys, tokens,
# or internal admin URLs here. Only safe public config (e.g. HTTPS API base URL).
# OpenAI keys belong in backend/.env or your server host’s secrets — see backend/.env.example.
# -----------------------------------------------------------------------------

# Production, internal testing, and store builds: HTTPS API (set in eas.json too).
# Web export (`npm run web:export`): this value is embedded in `dist/` — set before export or in Vercel/Netlify env.
EXPO_PUBLIC_BACKEND_URL=https://disabilityapp-production.up.railway.app

# Local API without hardcoding a URL: emulator uses 10.0.2.2:4000, iOS simulator 127.0.0.1:4000.
# Only effective when EXPO_PUBLIC_BACKEND_URL is unset. Never used in release builds.
# EXPO_PUBLIC_USE_LOCAL_BACKEND=true

# Explicit LAN / ngrok / tunnel (dev only in practice; blocked in release if non-public).
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.10:4000
