{
  "name": "clarodoc-mobile",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "eas:init": "eas init",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:prod:android": "eas build --profile production --platform android",
    "eas:build:prod:ios": "eas build --profile production --platform ios",
    "eas:submit:android": "eas submit --profile production --platform android --latest",
    "eas:submit:ios": "eas submit --profile production --platform ios --latest",
    "start": "expo start",
    "start:clean": "expo start --clear",
    "start:lan": "expo start --clear --host lan",
    "start:tunnel": "expo start --clear --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export -p web",
    "web:export": "npm run build",
    "web:preview": "serve dist -s -l tcp://0.0.0.0:4173"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "amazon-cognito-identity-js": "^6.3.12",
    "expo": "~55.0.9",
    "expo-secure-store": "~55.0.11",
    "expo-asset": "~55.0.12",
    "expo-constants": "~55.0.11",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-image-picker": "~55.0.16",
    "expo-linear-gradient": "~55.0.11",
    "expo-speech": "~55.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-preset-expo": "~55.0.8",
    "eas-cli": "^16.32.0",
    "expo-dev-client": "~55.0.22",
    "serve": "^14.2.6"
  },
  "private": true
}
